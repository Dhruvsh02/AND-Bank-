# AND Bank Environment Variables
# Copy this to .env and fill in your values

# ── DATABASE ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=andbank
DB_USER=andbank_user
DB_PASSWORD=your_strong_password_here

# ── REDIS ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── EMAIL (SMTP) ──────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ── SMS (Twilio) ──────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# ── PAYMENT (Razorpay) ────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── SERVICE PORTS ─────────────────────────────
GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
ACCOUNT_SERVICE_PORT=8003
TRANSACTION_SERVICE_PORT=8004
LOAN_SERVICE_PORT=8005
PAYMENT_SERVICE_PORT=8006
NOTIFICATION_SERVICE_PORT=8007
ADMIN_SERVICE_PORT=8008
CHAT_SERVICE_PORT=8009

# ── FRONTEND ──────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api
VITE_RAZORPAY_KEY_ID=your_razorpay_key
VITE_APP_NAME=AND Bank

# ── DJANGO ────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
